{
  "name": "starter-oracle-shatab",
  "version": "1.0.0",
  "description": "A starter backend boilerplate with Express, Prisma, TypeScript, and common utilities.",
  "author": "Md Shahriar Shatab",
  "license": "MIT",
  "keywords": [
    "express",
    "typescript",
    "oracledb",
    "typeorm",
    "backend",
    "boilerplate",
    "starter"
  ],
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node ./dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsgo",
    "build:old": "tsc",
    "lint": "eslint src --ignore-path .eslintignore --ext .ts",
    "//": "--- KEEP THESE FOR LATER (DO NOT RUN YET) ---",
    "typeorm": "typeorm-ts-node-commonjs",
    "gen": "typeorm-ts-node-commonjs migration:generate -d src/app/config/database.config.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/app/config/database.config.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/app/config/database.config.ts",
    "seed:admin": "ts-node src/app/seeds/seed.admin.ts",
    "seed:conv": "ts-node src/app/seeds/seeds.conv.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.956.0",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "exceljs": "^3.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "pg-query-stream": "^4.14.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.1.13",
    "stripe": "^20.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.18.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^22.13.1",
    "@types/nodemailer": "^6.4.17",
    "@types/redis": "^4.0.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20251221.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2",
    "typeorm": "^0.3.27",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
